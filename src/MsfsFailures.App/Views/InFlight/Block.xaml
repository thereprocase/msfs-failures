<UserControl x:Class="MsfsFailures.App.Views.InFlight.Block"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="3">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource TabBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="TitleText"
                               FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold"
                               Foreground="{DynamicResource AmberBrush}"/>
                    <ContentPresenter Grid.Column="2" x:Name="RightContent" VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <ContentPresenter x:Name="BodyContent" Margin="14"/>
        </DockPanel>
    </Border>
</UserControl>
