<?xml version="1.0" encoding="UTF-8"?>

<!--
  MsfsFailures Installer — WiX v5 source
  ========================================

  IMPORTANT: The UpgradeCode GUID below (0E5B50D6-65F8-4FAE-9C7C-F4900629D19E) is the
  permanent product identity. It MUST NEVER change across releases. Changing it would
  prevent MSI from recognising previous installations for upgrade/uninstall.

  Build command (run from repo root):
    python3 installer/gen_wxs.py   (regenerate Files.wxs from publish/win-x64)
    wix.exe build installer/MsfsFailures.Installer/Product.wxs ^
            installer/MsfsFailures.Installer/Files.wxs ^
      -arch x64 ^
      -out dist/MsfsFailures-0.1.0-x64.msi

  Files.wxs is auto-generated by installer/gen_wxs.py — do not edit manually.
  Re-run gen_wxs.py after any publish to update component list.
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="MsfsFailures"
           Manufacturer="thereprocase"
           Version="0.1.3.0"
           UpgradeCode="0E5B50D6-65F8-4FAE-9C7C-F4900629D19E"
           Scope="perMachine"
           InstallerVersion="500">

    <!-- Prevent downgrade -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of MsfsFailures is already installed." />

    <!-- Embed all files in a single CAB inside the MSI -->
    <MediaTemplate EmbedCab="yes" />

    <!-- ================================================================
         Directory layout
         ================================================================ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="MsfsFailures" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="MsfsFailures" />
    </StandardDirectory>

    <!-- ================================================================
         Start Menu shortcut component
         ================================================================ -->
    <ComponentGroup Id="StartMenuShortcuts" Directory="ApplicationProgramsFolder">
      <Component Id="ApplicationShortcut" Guid="B2A4C8E1-3F76-4D92-A5E0-1C9D7F823B45">
        <Shortcut Id="ApplicationStartMenuShortcut"
                  Name="MsfsFailures"
                  Description="MSFS Failure Tracker"
                  Target="[INSTALLFOLDER]MsfsFailures.App.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanUpShortcutFolder"
                      Directory="ApplicationProgramsFolder"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\thereprocase\MsfsFailures"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ================================================================
         Feature definition
         AppFiles component group is defined in Files.wxs (auto-generated)
         ================================================================ -->
    <Feature Id="Main" Title="MsfsFailures" Level="1">
      <ComponentGroupRef Id="StartMenuShortcuts" />
      <ComponentGroupRef Id="AppFiles" />
    </Feature>

  </Package>
</Wix>
