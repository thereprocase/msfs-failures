<Application x:Class="MsfsFailures.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cv="clr-namespace:MsfsFailures.App.Converters"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.xaml"/>
                <ResourceDictionary Source="Themes/Typography.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <cv:ConsumableToBrushConverter   x:Key="ConsumableBrush"/>
            <cv:ConsumableToWidthConverter   x:Key="ConsumableWidth"/>
            <cv:ConsumableToPercentConverter x:Key="ConsumablePct"/>
            <cv:StatusToBrushConverter       x:Key="StatusBrush"/>
            <cv:SeverityToBrushConverter     x:Key="SeverityBrush"/>
            <cv:BoolToVisibilityConverter    x:Key="BoolVis"/>
            <cv:BoolToVisibilityConverter    x:Key="BoolVisInv" Invert="True"/>
            <cv:AlertBoolToBrushConverter    x:Key="AlertBrush"/>
            <cv:SquawkCountToBrushConverter  x:Key="SquawkCountBrush"/>
            <cv:MelToBrushConverter          x:Key="MelBrush"/>
            <cv:IntZeroBrushConverter        x:Key="IntZeroBrush"/>
            <cv:RowBackgroundConverter       x:Key="RowBg"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
