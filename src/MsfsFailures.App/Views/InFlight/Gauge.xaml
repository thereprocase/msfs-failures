<UserControl x:Class="MsfsFailures.App.Views.InFlight.Gauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:MsfsFailures.App.Controls">
    <StackPanel Margin="0,0,12,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="LabelText"
                       FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{DynamicResource FaintBrush}"/>
            <TextBlock Grid.Column="1" x:Name="UnitText"
                       FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{DynamicResource FaintBrush}"/>
        </Grid>
        <TextBlock x:Name="ValueText"
                   FontFamily="{StaticResource MonoFont}" FontSize="20" FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   Margin="0,2,0,4"/>
        <c:MarkerBar x:Name="Bar" Height="6"
                     Min="0" Fill="{DynamicResource GreenBrush}"/>
    </StackPanel>
</UserControl>
