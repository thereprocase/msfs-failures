<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background tones -->
    <Color x:Key="BgColor">#FF0E0D0A</Color>
    <Color x:Key="PanelColor">#FF15130F</Color>
    <Color x:Key="Panel2Color">#FF1C1A14</Color>
    <Color x:Key="HeaderBgColor">#FF0A0907</Color>
    <Color x:Key="TabBgColor">#FF100E0A</Color>

    <SolidColorBrush x:Key="BgBrush"        Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="PanelBrush"     Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="Panel2Brush"    Color="{StaticResource Panel2Color}" />
    <SolidColorBrush x:Key="HeaderBgBrush"  Color="{StaticResource HeaderBgColor}" />
    <SolidColorBrush x:Key="TabBgBrush"     Color="{StaticResource TabBgColor}" />

    <!-- Rules / borders (alpha = 6%, 4%) -->
    <SolidColorBrush x:Key="BorderBrush"    Color="#0FFFFFFF" />
    <SolidColorBrush x:Key="RuleBrush"      Color="#0AFFFFFF" />
    <SolidColorBrush x:Key="DashedRuleBrush" Color="#14FFFFFF" />

    <!-- Text -->
    <Color x:Key="TextColor">#FFDDD6C4</Color>
    <Color x:Key="DimColor">#FF8A8270</Color>
    <Color x:Key="FaintColor">#FF54503F</Color>
    <SolidColorBrush x:Key="TextBrush"  Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="DimBrush"   Color="{StaticResource DimColor}" />
    <SolidColorBrush x:Key="FaintBrush" Color="{StaticResource FaintColor}" />

    <!-- Status colors -->
    <Color x:Key="GreenColor">#FFA8C97A</Color>
    <Color x:Key="AmberColor">#FFD4A24C</Color>
    <Color x:Key="OrangeColor">#FFD97757</Color>
    <Color x:Key="RedColor">#FFC25450</Color>
    <Color x:Key="CyanColor">#FF7FB8C4</Color>
    <Color x:Key="PurpleColor">#FFB59CC4</Color>
    <SolidColorBrush x:Key="GreenBrush"  Color="{StaticResource GreenColor}" />
    <SolidColorBrush x:Key="AmberBrush"  Color="{StaticResource AmberColor}" />
    <SolidColorBrush x:Key="OrangeBrush" Color="{StaticResource OrangeColor}" />
    <SolidColorBrush x:Key="RedBrush"    Color="{StaticResource RedColor}" />
    <SolidColorBrush x:Key="CyanBrush"   Color="{StaticResource CyanColor}" />
    <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource PurpleColor}" />

    <!-- Live row tint (green @ 4%) -->
    <SolidColorBrush x:Key="LiveTintBrush" Color="#0AA8C97A" />

    <!-- Action button red border (red @ 30%) -->
    <SolidColorBrush x:Key="RedBorderSoftBrush" Color="#4DC25450" />

    <!-- Bar track (white @ 6%) -->
    <SolidColorBrush x:Key="BarTrackBrush" Color="#0FFFFFFF" />

</ResourceDictionary>
