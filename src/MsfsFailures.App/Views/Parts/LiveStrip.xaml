<UserControl x:Class="MsfsFailures.App.Views.Parts.LiveStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MsfsFailures.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:HomeViewModel}">
    <UserControl.Resources>
        <Style TargetType="TextBlock" x:Key="KvKey">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="{DynamicResource FaintBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="KvVal">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,18,0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="18,10">
        <StackPanel Orientation="Horizontal">
            <Ellipse Width="7" Height="7" Margin="0,0,6,0" Fill="{DynamicResource GreenBrush}">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1" To="0.35" Duration="0:0:1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
            <TextBlock Text="LIVE" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource GreenBrush}" Margin="0,0,18,0" VerticalAlignment="Center"/>

            <TextBlock Text="{Binding LiveAircraft.Tail}" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource TextBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding LiveAircraft.Type}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                       Foreground="{DynamicResource DimBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="·" FontFamily="{StaticResource MonoFont}" FontSize="11"
                       Foreground="{DynamicResource FaintBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding LiveAircraft.LiveState.Phase}" FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource AmberBrush}" Margin="0,0,22,0" VerticalAlignment="Center"/>

            <ItemsControl ItemsSource="{Binding LiveStripPairs}">
                <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Key}"   Style="{StaticResource KvKey}"/>
                            <TextBlock Text="{Binding Value}" Style="{StaticResource KvVal}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
