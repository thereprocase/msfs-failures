<UserControl x:Class="MsfsFailures.App.Views.InFlight.Trend"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:MsfsFailures.App.Controls">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="TitleText"
                       FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{DynamicResource FaintBrush}"/>
            <TextBlock Grid.Column="1" x:Name="UnitText"
                       FontFamily="{StaticResource MonoFont}" FontSize="9" Foreground="{DynamicResource FaintBrush}"/>
        </Grid>
        <c:Spark x:Name="SparkChart" Height="32" Margin="0,4"
                 Stroke="{DynamicResource GreenBrush}" Fill="True"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{DynamicResource FaintBrush}">
                <Run Text="NOW "/><Run x:Name="NowText" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
            </TextBlock>
            <TextBlock Grid.Column="1" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{DynamicResource FaintBrush}">
                <Run Text="PEAK "/><Run x:Name="PeakText" FontWeight="SemiBold"/>
            </TextBlock>
            <TextBlock Grid.Column="2" FontFamily="{StaticResource MonoFont}" FontSize="10" Foreground="{DynamicResource FaintBrush}">
                <Run Text="AVG "/><Run x:Name="AvgText" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
            </TextBlock>
        </Grid>
    </StackPanel>
</UserControl>
